# Copy this file to .env and modify the values as needed
# The .env file is already included in .gitignore for security

# =============================================================================
# LLM Configuration
# =============================================================================
# Choose your LLM provider and URL
# Options:
# - LM Studio: http://host.docker.internal:1234/v1
# - Ollama: http://host.docker.internal:11434
# - Docker: http://host.docker.internal:12434
LLM_API_URL=http://host.docker.internal:1234/v1

# =============================================================================
# Model Configuration
# =============================================================================
# Single model configuration (required)
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Device to run models on (cpu/cuda/mps)
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu

# =============================================================================
# Agent Configuration
# =============================================================================
# Token budget for agent operations
DEFAULT_TOKEN_BUDGET=8192

# Iteration limits for agent processing
DEFAULT_MAX_ITERATIONS=10
MIN_MAX_ITERATIONS=1
MAX_MAX_ITERATIONS=30

# Character limits for various inputs
MAX_CUSTOM_INSTRUCTIONS_CHARS=2000
MAX_SYSTEM_ROLE_CHARS=500
MAX_TOOL_INSTRUCTION_CHARS=500

# Intent agent configuration
INTENT_AGENT_MAX_ITERATIONS=1

# Coverage-based iteration limits
MAX_ITERATIONS_SUFFICIENT_COVERAGE=2
MAX_ITERATIONS_PROBABLY_SUFFICIENT_COVERAGE=4

# Web search iteration bonus
WEB_SEARCH_ITERATION_BONUS=2

# =============================================================================
# Docling PDF Processing Configuration
# =============================================================================
# OCR settings - set to True if processing scanned PDFs
DOCLING_DO_OCR=False

# Table structure recognition
DOCLING_DO_TABLE_STRUCTURE=True

# Table processing mode: ACCURATE (slower) or FAST (faster)
DOCLING_TABLE_MODE=FAST

# Force full page OCR - keep False for digital PDFs to avoid noise
DOCLING_FORCE_FULL_PAGE_OCR=False

# Formula enrichment - enable if PDFs contain mathematical formulas
DOCLING_DO_FORMULA_ENRICHMENT=False

# =============================================================================
# Weaviate Configuration
# =============================================================================
# Hybrid search blend (0.0=pure vector, 1.0=pure keyword)
WEAVIATE_HYBRID_ALPHA=0.7

# Weaviate default max results when query limit is not explicitly set
QUERY_DEFAULTS_LIMIT=20

# =============================================================================
# Browser Capture (Selkies) Configuration
# =============================================================================
# Browser capture (Selkies) UI feature flags
# Enable clipboard support between host and browser-capture session
SELKIES_CLIPBOARD_ENABLED=true
SELKIES_CLIPBOARD_BRIDGE_ENABLED=true
# Disable gaming controls in sidebar
SELKIES_GAMEPAD_ENABLED=false
SELKIES_UI_SIDEBAR_SHOW_GAMEPADS=false
SELKIES_UI_SIDEBAR_SHOW_GAMING_MODE=false
# Disable sharing and apps sections in sidebar
SELKIES_UI_SIDEBAR_SHOW_SHARING=false
SELKIES_UI_SIDEBAR_SHOW_APPS=false

# =============================================================================
# Supabase Parallel Migration (optional)
# =============================================================================
# Self-hosted Supabase API URL exposed by docker-compose.supabase.yml
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# Generate real anon/service keys from the JWT secret before enabling frontend access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
SUPABASE_POSTGRES_PASSWORD=postgres
SUPABASE_POSTGRES_DB=postgres
SUPABASE_DB_PORT=54322
SUPABASE_API_PORT=54321
SUPABASE_PUBLIC_URL=http://localhost:54321
SUPABASE_STORAGE_URL=http://supabase-kong:8000/storage/v1
SUPABASE_STORAGE_BUCKET=pdfs

# Backend service-role database access for best-effort dual-write/parity checks.
RAG_SUPABASE_DB_URL=postgresql://postgres:postgres@supabase-db:5432/postgres
RAG_SUPABASE_DUAL_WRITE=false
RAG_SUPABASE_PARITY_CHECK=false

# Frontend feature flags. Keep false until migration validation passes.
NEXT_PUBLIC_USE_SUPABASE_THREADS=false
NEXT_PUBLIC_USE_SUPABASE_MESSAGES=false
NEXT_PUBLIC_USE_SUPABASE_FILES=false
NEXT_PUBLIC_USE_SUPABASE_REALTIME=false
NEXT_PUBLIC_USE_SUPABASE_STORAGE=false

# Docker migration runner URLs.
MIGRATION_SOURCE_DATABASE_URL=postgresql://postgres:postgres@postgresql:5432/askpdf
MIGRATION_TARGET_DATABASE_URL=postgresql://postgres:postgres@supabase-db:5432/postgres
MIGRATION_STATIC_DIR=/static
