# Copy this file to .env and modify the values as needed
# The .env file is already included in .gitignore for security

# =============================================================================
# LLM Configuration
# =============================================================================
# Choose your LLM provider and URL
# Options:
# - LM Studio: http://host.docker.internal:1234/v1
# - Ollama: http://host.docker.internal:11434
# - Docker: http://host.docker.internal:12434
LLM_API_URL=http://host.docker.internal:1234/v1

# =============================================================================
# Model Configuration
# =============================================================================
# Single model configuration (required)
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Device to run models on (cpu/cuda/mps)
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu

# =============================================================================
# Agent Configuration
# =============================================================================
# Token budget for agent operations
DEFAULT_TOKEN_BUDGET=8192

# Iteration limits for agent processing
DEFAULT_MAX_ITERATIONS=10
MIN_MAX_ITERATIONS=1
MAX_MAX_ITERATIONS=30

# Character limits for various inputs
MAX_CUSTOM_INSTRUCTIONS_CHARS=2000
MAX_SYSTEM_ROLE_CHARS=500
MAX_TOOL_INSTRUCTION_CHARS=500

# Intent agent configuration
INTENT_AGENT_MAX_ITERATIONS=1

# Coverage-based iteration limits
MAX_ITERATIONS_SUFFICIENT_COVERAGE=2
MAX_ITERATIONS_PROBABLY_SUFFICIENT_COVERAGE=4

# Web search iteration bonus
WEB_SEARCH_ITERATION_BONUS=2

# =============================================================================
# Docling PDF Processing Configuration
# =============================================================================
# OCR settings - set to True if processing scanned PDFs
DOCLING_DO_OCR=True

# Table structure recognition
DOCLING_DO_TABLE_STRUCTURE=True

# Table processing mode: ACCURATE (slower) or FAST (faster)
DOCLING_TABLE_MODE=ACCURATE

# Force full page OCR - keep False for digital PDFs to avoid noise
DOCLING_FORCE_FULL_PAGE_OCR=False

# Formula enrichment - enable if PDFs contain mathematical formulas
DOCLING_DO_FORMULA_ENRICHMENT=False

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection strings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgresql:5432/askpdf
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgresql:5432/test_askpdf

# Database connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
